{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:Scan"
      ],
      "Resource": [
         "arn:aws:dynamodb:eu-west-1:851725425406:table/quiz-questions",
        "arn:aws:dynamodb:eu-west-1:851725425406:table/quiz-participants",
        "arn:aws:dynamodb:eu-west-1:851725425406:table/quiz-feedback"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    }
  ]
}
